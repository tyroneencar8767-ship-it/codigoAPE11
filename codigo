    portafolioD = portafolioD * (porcentajePD / 100.0);
        
    totalES = evaluacionS + portafolioD;

    promedioES = totalES * 0.35;
    printf("El ponderado de su ES es: %.2f\n\n", promedioES);
    return promedioES;
}

